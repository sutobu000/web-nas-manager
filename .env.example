# Authentication
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate hash:   node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
# NOTE: in docker-compose (.env), escape every literal '$' in the hash as '$$'
JWT_SECRET=your-secret-key-here
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here

# --- Optional ---

# Local development only (next dev): point DATA_ROOT at a test directory.
# DATA_ROOT=./dev-data

# Override the drives config file location (default: /config/drives.json).
# For local dev, point it at a file in the project root.
# DRIVES_CONFIG_PATH=./drives.json

# Define drives inline instead of a file (a JSON array). Takes priority over the file.
# STORAGE_DRIVES_JSON=[{"id":"data","name":"Data","icon":"hdd"}]

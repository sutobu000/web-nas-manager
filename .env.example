# Docker Compose volume mapping
# Windows drive paths (Linux/Mac example: /mnt/hdd1, /Volumes/Drive).
# The number of drives must match STORAGE_DRIVES in src/lib/constants.ts.
HDD_001_PATH=E:\
HDD_002_PATH=F:\
SSD_001_PATH=G:\
SSD_002_PATH=H:\

# Authentication
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate hash:   node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
# NOTE: in docker-compose (.env), escape every literal '$' in the hash as '$$'
JWT_SECRET=your-secret-key-here
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here

# Local development only (next dev): point DATA_ROOT at a test directory.
# Ignored by Docker. Uncomment to use.
# DATA_ROOT=./dev-data
